from fastapi import FastAPI, HTTPException
from pydantic import BaseModel

app = FastAPI(title="{{ .ProjectName }}", version="{{ .Version }}")
users = {"1": {"id": "1", "name": "Alice", "email": "alice@example.com"}}

class UserIn(BaseModel):
    name: str
    email: str

@app.get("/health")
def health(): return {"status": "ok", "service": "{{ .ProjectName }}"}

@app.get("/api/v1/users")
def list_users(): return list(users.values())

@app.post("/api/v1/users", status_code=201)
def create_user(user: UserIn):
    uid = str(len(users) + 1)
    users[uid] = {"id": uid, **user.model_dump()}
    return users[uid]

@app.get("/api/v1/users/{uid}")
def get_user(uid: str):
    if uid not in users: raise HTTPException(404, "not found")
    return users[uid]

@app.put("/api/v1/users/{uid}")
def update_user(uid: str, user: UserIn):
    if uid not in users: raise HTTPException(404, "not found")
    users[uid] = {"id": uid, **user.model_dump()}
    return users[uid]

@app.delete("/api/v1/users/{uid}", status_code=204)
def delete_user(uid: str):
    if uid not in users: raise HTTPException(404, "not found")
    del users[uid]