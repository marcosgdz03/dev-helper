const express = require('express');
const app = express();
const PORT = process.env.PORT || 3000;

app.use(express.json());

app.get('/health', (req, res) => {
  res.json({ status: 'ok', service: '{{ .ProjectName }}' });
});

const users = [{ id: '1', name: 'Alice', email: 'alice@example.com' }];

app.get('/api/v1/users', (_, res) => res.json(users));
app.post('/api/v1/users', (req, res) => {
  const user = { id: String(users.length + 1), ...req.body };
  users.push(user);
  res.status(201).json(user);
});
app.get('/api/v1/users/:id', (req, res) => {
  const u = users.find(u => u.id === req.params.id);
  if (!u) return res.status(404).json({ error: 'not found' });
  res.json(u);
});
app.put('/api/v1/users/:id', (req, res) => {
  const idx = users.findIndex(u => u.id === req.params.id);
  if (idx === -1) return res.status(404).json({ error: 'not found' });
  users[idx] = { id: req.params.id, ...req.body };
  res.json(users[idx]);
});
app.delete('/api/v1/users/:id', (req, res) => {
  const idx = users.findIndex(u => u.id === req.params.id);
  if (idx === -1) return res.status(404).json({ error: 'not found' });
  users.splice(idx, 1);
  res.status(204).send();
});

app.listen(PORT, () => console.log(`{{ .ProjectName }} on :${PORT}`));