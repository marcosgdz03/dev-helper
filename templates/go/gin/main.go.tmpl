// Package main is the entry point for {{ .ProjectName }}.
package main

import (
	"log"
	"net/http"
	"os"

	"github.com/gin-gonic/gin"
)

const (
	defaultPort = "8080"
)

// @title      {{ .ProjectName }} API
// @version    {{ .Version }}
// @author     {{ .Author }}
// @summary    {{ .ProjectName }} backend API
func main() {
	port := os.Getenv("PORT")
	if port == "" {
		port = defaultPort
	}

	r := gin.Default()

	// Health check
	r.GET("/health", func(c *gin.Context) {
		c.JSON(http.StatusOK, gin.H{
			"status":  "ok",
			"service": "{{ .ProjectName }}",
		})
	})

	// API v1 group
	v1 := r.Group("/api/v1")
	{
		users := v1.Group("/users")
		{
			users.GET("", getUsers)
			users.POST("", createUser)
		}
	}

	log.Printf("{{ .ProjectName }} starting on :%s", port)
	if err := r.Run(":" + port); err != nil {
		log.Fatalf("server failed: %v", err)
	}
}
